<link rel="stylesheet" href="/style.css">
<h1>Přidat knihu</h1>
<form action="/books" method="POST" enctype="multipart/form-data">
    <input type="text" name="title" placeholder="Název knihy" required><br><br>
    <input type="text" name="author" placeholder="Autor" required><br><br>
    <input type="number" name="pages" placeholder="Počet stran" required><br><br>
    <textarea name="description" placeholder="Popis knihy" required></textarea><br><br>
    <label>Obrázek obálky:</label><br>
    <input type="file" name="image"><br><br>
    <button type="submit">Uložit knihu</button>
</form>
<p><a href="/books">Zpět na seznam</a></p>